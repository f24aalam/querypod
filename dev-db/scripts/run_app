#!/usr/bin/env bash

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/common.sh"

platform=""
target=""
port=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)
      [[ $# -ge 2 ]] || die "Missing value for --platform"
      platform="$2"
      shift 2
      ;;
    --target)
      [[ $# -ge 2 ]] || die "Missing value for --target"
      target="$2"
      shift 2
      ;;
    --port)
      [[ $# -ge 2 ]] || die "Missing value for --port"
      port="$2"
      shift 2
      ;;
    *)
      die "Unsupported argument '$1'. Use --platform, --target, and --port."
      ;;
  esac
done

[[ -n "${platform}" ]] || die "PLATFORM is required. Example: make run-app PLATFORM=linux TARGET=mysql"
[[ "${platform}" == "linux" ]] || die "Unsupported platform '${platform}'. Only linux is supported right now."
[[ -n "${target}" ]] || die "TARGET is required. Example: make run-app PLATFORM=linux TARGET=mysql"
if [[ "${target}" == *","* ]]; then
  die "TARGET accepts exactly one value. Use mysql, postgres, sakila, world, employees, or dvdrental."
fi

kind=""
case "${target}" in
  mysql)
    kind="mysql"
    ;;
  postgres)
    kind="postgres"
    ;;
  sakila|world|employees)
    kind="mysql"
    ;;
  dvdrental)
    kind="postgres"
    ;;
  *)
    die "Unsupported TARGET '${target}'. Use mysql, postgres, sakila, world, employees, or dvdrental."
    ;;
esac

if [[ -n "${port}" ]] && ! [[ "${port}" =~ ^[0-9]+$ ]]; then
  die "PORT must be a single integer value."
fi

current_port=""
suggested_port=""
command_hint=""
selection_hint="TARGET=${target}"

case "${kind}" in
  mysql)
    current_port="${MYSQL_PORT}"
    suggested_port="3307"
    command_hint="make run-app PLATFORM=linux ${selection_hint} PORT=${suggested_port}"
    ;;
  postgres)
    current_port="${POSTGRES_PORT}"
    suggested_port="5433"
    command_hint="make run-app PLATFORM=linux ${selection_hint} PORT=${suggested_port}"
    ;;
  *)
    die "Unable to resolve launch kind for target '${target}'."
    ;;
esac

if [[ -z "${port}" ]] && is_port_in_use "${current_port}"; then
  die "Host port ${current_port} is already in use, so Docker cannot expose the ${kind} service there. Retry with a one-off override, for example: ${command_hint}"
fi

if [[ -n "${port}" ]]; then
  case "${kind}" in
    mysql)
      export QUERYPOD_MYSQL_PORT="${port}"
      ;;
    postgres)
      export QUERYPOD_PG_PORT="${port}"
      ;;
  esac
fi

exec "${SCRIPT_DIR}/run_linux_app" "${target}"
